<!DOCTYPE html>
<html lang="it">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width,initial-scale=1,maximum-scale=1,user-scalable=no"/>
<meta name="apple-mobile-web-app-capable" content="yes"/>
<meta name="apple-mobile-web-app-status-bar-style" content="black-translucent"/>
<meta name="apple-mobile-web-app-title" content="SafeHer"/>
<meta name="theme-color" content="#6D2E46"/>
<link rel="manifest" href="manifest.json"/>
<link rel="apple-touch-icon" href="icons/icon-192.png"/>
<title>SafeHer</title>
<style>
:root{
  --berry:#6D2E46;--rose:#A26769;--accent:#C0314F;--light:#FBEAF0;--cream:#FCF6F5;
  --white:#FFFFFF;--dark:#2A1020;--gray:#F5F4F4;--border:#E8D5DC;
  --text:#1A0A12;--muted:#7A5060;
}
*{box-sizing:border-box;margin:0;padding:0;-webkit-tap-highlight-color:transparent;}
html,body{height:100%;overflow:hidden;font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',sans-serif;background:var(--berry);}
body{display:flex;flex-direction:column;}

/* ── HEADER ── */
.header{background:var(--berry);padding:env(safe-area-inset-top,16px) 16px 14px;display:flex;align-items:center;gap:10px;flex-shrink:0;}
.header-icon{width:36px;height:36px;background:var(--light);border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:18px;}
.header-title{color:var(--white);font-size:20px;font-weight:700;letter-spacing:-.3px;}
.header-sub{color:#F4C0D1;font-size:12px;margin-top:1px;}
.header-right{margin-left:auto;}
.voice-indicator{width:10px;height:10px;border-radius:50%;background:#555;transition:background .3s;}
.voice-indicator.on{background:#2ecc71;animation:pulse 1.2s infinite;}
@keyframes pulse{0%,100%{opacity:1}50%{opacity:.4}}

/* ── TABS ── */
.tabs{background:var(--berry);display:flex;padding:0 8px;flex-shrink:0;border-bottom:1px solid rgba(255,255,255,.1);}
.tab{flex:1;padding:10px 4px 12px;color:rgba(255,255,255,.5);font-size:11px;text-align:center;cursor:pointer;border:none;background:transparent;display:flex;flex-direction:column;align-items:center;gap:4px;transition:color .2s;border-bottom:2px solid transparent;}
.tab.active{color:var(--white);border-bottom:2px solid var(--light);}
.tab-icon{font-size:20px;}

/* ── CONTENT ── */
.content{flex:1;background:var(--cream);overflow-y:auto;-webkit-overflow-scrolling:touch;}
.screen{display:none;padding:20px 16px;padding-bottom:calc(20px + env(safe-area-inset-bottom,0px));}
.screen.active{display:block;}

/* ── SOS SCREEN ── */
.sos-wrapper{display:flex;flex-direction:column;align-items:center;padding-top:8px;}
.sos-hint{font-size:13px;color:var(--muted);margin-bottom:16px;text-align:center;}
.sos-btn{width:180px;height:180px;border-radius:50%;background:var(--accent);border:6px solid var(--berry);color:var(--white);display:flex;flex-direction:column;align-items:center;justify-content:center;gap:4px;cursor:pointer;user-select:none;-webkit-user-select:none;box-shadow:0 0 0 16px rgba(192,49,79,.15);transition:transform .1s,background .1s;position:relative;}
.sos-btn:active{transform:scale(.95);}
.sos-btn.pressing{background:#9B0020;box-shadow:0 0 0 20px rgba(155,0,32,.2);}
.sos-btn.fired{background:#6D0015;}
.sos-emoji{font-size:42px;}
.sos-text{font-size:26px;font-weight:800;letter-spacing:2px;}
.sos-sub{font-size:11px;opacity:.8;}
.sos-ring{position:absolute;width:100%;height:100%;border-radius:50%;border:3px solid var(--accent);animation:none;}
.pressing .sos-ring{animation:sosPulse .8s infinite;}
@keyframes sosPulse{0%{transform:scale(1);opacity:.8}100%{transform:scale(1.3);opacity:0}}

.sos-progress-wrap{width:190px;margin:12px auto 4px;height:6px;background:var(--border);border-radius:3px;overflow:hidden;display:none;}
.sos-progress-wrap.visible{display:block;}
.sos-progress{height:100%;width:0;background:var(--accent);border-radius:3px;transition:width .05s linear;}

.sos-alert{background:var(--berry);color:var(--white);border-radius:14px;padding:14px 16px;margin-top:16px;display:none;text-align:center;font-size:14px;line-height:1.5;}
.sos-alert.show{display:block;}
.sos-alert strong{display:block;font-size:16px;margin-bottom:4px;}

.quick-grid{display:grid;grid-template-columns:1fr 1fr;gap:10px;margin-top:20px;}
.quick-card{background:var(--white);border:1px solid var(--border);border-radius:14px;padding:14px 10px;display:flex;flex-direction:column;align-items:center;gap:6px;cursor:pointer;transition:background .15s;}
.quick-card:active{background:var(--light);}
.quick-card .qc-icon{font-size:26px;}
.quick-card .qc-label{font-size:12px;color:var(--muted);text-align:center;font-weight:500;}

/* ── VOICE SCREEN ── */
.card{background:var(--white);border:1px solid var(--border);border-radius:16px;padding:16px;margin-bottom:14px;}
.card-title{font-size:15px;font-weight:700;color:var(--berry);margin-bottom:4px;}
.card-desc{font-size:13px;color:var(--muted);line-height:1.5;margin-bottom:12px;}
.toggle-row{display:flex;align-items:center;justify-content:space-between;}
.toggle-label{font-size:14px;font-weight:600;color:var(--text);}
.toggle-switch{width:50px;height:28px;border-radius:14px;background:#ccc;position:relative;cursor:pointer;transition:background .25s;flex-shrink:0;}
.toggle-switch.on{background:var(--berry);}
.toggle-knob{width:22px;height:22px;border-radius:50%;background:var(--white);position:absolute;top:3px;left:3px;transition:left .25s;box-shadow:0 1px 3px rgba(0,0,0,.2);}
.toggle-switch.on .toggle-knob{left:25px;}

.kw-display{display:flex;align-items:center;gap:10px;background:var(--light);border-radius:10px;padding:10px 12px;margin-top:12px;}
.kw-value{flex:1;font-size:15px;font-weight:600;color:var(--berry);}
.kw-none{flex:1;font-size:14px;color:var(--muted);font-style:italic;}
.btn-small{padding:7px 14px;border-radius:8px;border:1.5px solid var(--berry);background:transparent;color:var(--berry);font-size:13px;font-weight:600;cursor:pointer;}
.btn-small:active{background:var(--light);}

.kw-form{background:var(--gray);border-radius:12px;padding:14px;margin-top:12px;display:none;}
.kw-form.open{display:block;}
.kw-form p{font-size:12px;color:var(--muted);margin-bottom:10px;line-height:1.5;}
.input{width:100%;padding:11px 14px;border-radius:10px;border:1.5px solid var(--border);font-size:15px;background:var(--white);color:var(--text);outline:none;-webkit-appearance:none;}
.input:focus{border-color:var(--berry);}
.btn-row{display:flex;gap:8px;margin-top:10px;}
.btn-primary{flex:1;padding:11px;border-radius:10px;border:none;background:var(--berry);color:var(--white);font-size:14px;font-weight:700;cursor:pointer;}
.btn-secondary{flex:1;padding:11px;border-radius:10px;border:1.5px solid var(--border);background:var(--white);color:var(--text);font-size:14px;cursor:pointer;}

.listening-bar{background:var(--berry);color:var(--white);border-radius:12px;padding:12px 14px;display:none;align-items:center;gap:10px;margin-top:12px;}
.listening-bar.show{display:flex;}
.listening-dot{width:10px;height:10px;border-radius:50%;background:#2ecc71;animation:pulse 1s infinite;flex-shrink:0;}
.listening-text{font-size:13px;flex:1;}
.listening-kw{font-weight:700;}

.test-btn{width:100%;padding:13px;border-radius:12px;border:2px solid var(--berry);background:transparent;color:var(--berry);font-size:15px;font-weight:700;cursor:pointer;margin-top:4px;}
.test-btn:active{background:var(--light);}

/* ── CONTACTS SCREEN ── */
.contact-item{background:var(--white);border:1px solid var(--border);border-radius:14px;padding:13px 14px;display:flex;align-items:center;gap:12px;margin-bottom:10px;}
.avatar{width:44px;height:44px;border-radius:50%;background:var(--light);display:flex;align-items:center;justify-content:center;font-size:15px;font-weight:700;color:var(--berry);flex-shrink:0;}
.contact-info{flex:1;}
.contact-name{font-size:15px;font-weight:600;color:var(--text);}
.contact-rel{font-size:12px;color:var(--muted);margin-top:2px;}
.contact-actions{display:flex;gap:6px;}
.icon-btn{width:36px;height:36px;border-radius:50%;border:1px solid var(--border);background:var(--gray);display:flex;align-items:center;justify-content:center;font-size:17px;cursor:pointer;}
.icon-btn:active{background:var(--light);}
.add-contact-btn{width:100%;padding:13px;border-radius:12px;border:2px dashed var(--border);background:transparent;color:var(--berry);font-size:15px;font-weight:600;cursor:pointer;margin-top:4px;}
.add-contact-btn:active{background:var(--light);}

/* ── TIMER SCREEN ── */
.timer-wrap{display:flex;flex-direction:column;align-items:center;padding-top:4px;}
.timer-circle{width:160px;height:160px;border-radius:50%;border:5px solid var(--berry);background:var(--white);display:flex;flex-direction:column;align-items:center;justify-content:center;margin-bottom:16px;position:relative;}
.timer-svg{position:absolute;top:-5px;left:-5px;width:170px;height:170px;transform:rotate(-90deg);}
.timer-track{fill:none;stroke:var(--border);stroke-width:5;}
.timer-prog{fill:none;stroke:var(--berry);stroke-width:5;stroke-linecap:round;stroke-dasharray:502;stroke-dashoffset:502;transition:stroke-dashoffset .9s linear;}
.timer-num{font-size:40px;font-weight:800;color:var(--berry);line-height:1;}
.timer-lbl{font-size:12px;color:var(--muted);margin-top:4px;}
.timer-msg{font-size:13px;color:var(--muted);text-align:center;margin-bottom:16px;padding:0 8px;line-height:1.5;}
.dur-grid{display:grid;grid-template-columns:1fr 1fr;gap:10px;margin-bottom:16px;width:100%;}
.dur-btn{padding:12px;border-radius:12px;border:1.5px solid var(--border);background:var(--white);font-size:14px;font-weight:500;color:var(--text);cursor:pointer;transition:all .15s;}
.dur-btn.sel{border-color:var(--berry);background:var(--light);color:var(--berry);font-weight:700;}
.dur-btn:active{background:var(--light);}
.timer-main-btn{width:100%;padding:15px;border-radius:14px;border:none;background:var(--berry);color:var(--white);font-size:17px;font-weight:700;cursor:pointer;transition:background .2s;}
.timer-main-btn.stop{background:var(--gray);color:var(--text);border:1.5px solid var(--border);}

/* ── FAKE CALL ── */
.fake-call-overlay{position:fixed;inset:0;background:var(--berry);z-index:100;display:none;flex-direction:column;align-items:center;justify-content:center;gap:20px;padding:40px 24px;}
.fake-call-overlay.show{display:flex;}
.fake-call-name{font-size:32px;font-weight:800;color:var(--white);}
.fake-call-sub{font-size:16px;color:#F4C0D1;}
.fake-call-avatar{width:90px;height:90px;border-radius:50%;background:var(--light);display:flex;align-items:center;justify-content:center;font-size:36px;font-weight:800;color:var(--berry);}
.call-btns{display:flex;gap:40px;margin-top:20px;}
.call-btn{width:70px;height:70px;border-radius:50%;border:none;display:flex;align-items:center;justify-content:center;font-size:28px;cursor:pointer;}
.call-btn.decline{background:#e74c3c;}
.call-btn.accept{background:#2ecc71;}

/* ── MODAL ── */
.modal-overlay{position:fixed;inset:0;background:rgba(0,0,0,.5);z-index:50;display:none;align-items:flex-end;justify-content:center;}
.modal-overlay.open{display:flex;}
.modal{background:var(--white);border-radius:20px 20px 0 0;padding:20px 20px calc(20px + env(safe-area-inset-bottom,0px));width:100%;max-width:480px;}
.modal h3{font-size:18px;font-weight:700;color:var(--berry);margin-bottom:16px;}
.modal-field{margin-bottom:12px;}
.modal-field label{font-size:13px;color:var(--muted);display:block;margin-bottom:5px;font-weight:500;}

/* ── SECTION LABEL ── */
.section-lbl{font-size:11px;font-weight:700;color:var(--muted);letter-spacing:.8px;text-transform:uppercase;margin-bottom:10px;margin-top:2px;}

/* ── TOAST ── */
.toast{position:fixed;bottom:calc(90px + env(safe-area-inset-bottom,0px));left:50%;transform:translateX(-50%) translateY(20px);background:var(--berry);color:var(--white);padding:12px 20px;border-radius:20px;font-size:14px;font-weight:600;opacity:0;transition:all .3s;pointer-events:none;white-space:nowrap;z-index:200;}
.toast.show{opacity:1;transform:translateX(-50%) translateY(0);}

/* ── INSTALL BANNER ── */
.install-banner{background:var(--white);border:1px solid var(--border);border-radius:14px;padding:14px;margin-bottom:16px;display:none;}
.install-banner.show{display:block;}
.install-banner p{font-size:13px;color:var(--text);margin-bottom:10px;line-height:1.5;}
.install-banner strong{color:var(--berry);}
</style>
</head>
<body>

<div class="header">
  <div class="header-icon">🛡️</div>
  <div>
    <div class="header-title">SafeHer</div>
    <div class="header-sub">La tua sicurezza, sempre con te</div>
  </div>
  <div class="header-right">
    <div class="voice-indicator" id="voiceIndicator" title="Voce attiva"></div>
  </div>
</div>

<div class="tabs">
  <button class="tab active" onclick="showTab('sos')" id="tab-sos">
    <span class="tab-icon">🆘</span>SOS
  </button>
  <button class="tab" onclick="showTab('voice')" id="tab-voice">
    <span class="tab-icon">🎙️</span>Voce
  </button>
  <button class="tab" onclick="showTab('contacts')" id="tab-contacts">
    <span class="tab-icon">👥</span>Contatti
  </button>
  <button class="tab" onclick="showTab('timer')" id="tab-timer">
    <span class="tab-icon">⏱️</span>Timer
  </button>
</div>

<div class="content">

  <!-- SOS -->
  <div class="screen active" id="screen-sos">
    <div class="install-banner" id="installBanner">
      <p>📲 <strong>Installa SafeHer</strong> sulla home del telefono per usarla come un'app vera, anche offline!</p>
      <button class="btn-primary" onclick="installApp()" style="width:100%">Installa ora</button>
    </div>

    <div class="sos-wrapper">
      <div class="sos-hint" id="sosHint">Tieni premuto 3 secondi per inviare l'SOS</div>

      <button class="sos-btn" id="sosBtn"
        onmousedown="startSOS()" onmouseup="cancelSOS()" onmouseleave="cancelSOS()"
        ontouchstart="startSOS(event)" ontouchend="cancelSOS()" ontouchcancel="cancelSOS()">
        <div class="sos-ring" id="sosRing"></div>
        <div class="sos-emoji">🚨</div>
        <div class="sos-text">SOS</div>
        <div class="sos-sub">AIUTO</div>
      </button>

      <div class="sos-progress-wrap" id="sosProgressWrap">
        <div class="sos-progress" id="sosProgress"></div>
      </div>

      <div class="sos-alert" id="sosAlert">
        <strong>✅ Allarme inviato!</strong>
        I tuoi contatti sono stati avvisati con la tua posizione GPS. Rimani al sicuro.
      </div>
    </div>

    <div style="margin-top:20px;">
      <div class="section-lbl">Azioni rapide</div>
      <div class="quick-grid">
        <div class="quick-card" onclick="startFakeCall()">
          <div class="qc-icon">📞</div>
          <div class="qc-label">Chiamata fittizia</div>
        </div>
        <div class="quick-card" onclick="sendLocation()">
          <div class="qc-icon">📍</div>
          <div class="qc-label">Invia posizione</div>
        </div>
        <div class="quick-card" onclick="call112()">
          <div class="qc-icon">🏥</div>
          <div class="qc-label">Chiama 112</div>
        </div>
        <div class="quick-card" onclick="startRecording()">
          <div class="qc-icon" id="recIcon">🎙️</div>
          <div class="qc-label" id="recLabel">Registra audio</div>
        </div>
      </div>
    </div>
  </div>

  <!-- VOICE -->
  <div class="screen" id="screen-voice">
    <div class="card">
      <div class="card-title">🎙️ Attivazione vocale SOS</div>
      <div class="card-desc">Imposta una frase segreta. Pronunciala e SafeHer attiva l'SOS automaticamente, senza toccare il telefono.</div>
      <div class="toggle-row">
        <span class="toggle-label" id="voiceToggleLabel">Non attiva</span>
        <div class="toggle-switch" id="voiceToggle" onclick="toggleVoice()">
          <div class="toggle-knob"></div>
        </div>
      </div>
    </div>

    <div class="card">
      <div class="card-title">🔑 Frase segreta</div>
      <div class="card-desc">Scegli una frase innocua che solo tu conosci. Es: <em>"ho dimenticato le chiavi"</em> o <em>"chiama la nonna"</em>.</div>
      <div class="kw-display">
        <span id="kwShow" class="kw-none">Nessuna frase impostata</span>
        <button class="btn-small" onclick="openKwForm()" id="kwEditBtn">Imposta</button>
      </div>
      <div class="kw-form" id="kwForm">
        <p>Scrivi la frase che vuoi usare come comando segreto. Deve essere pronunciabile in modo naturale.</p>
        <input class="input" type="text" id="kwInput" placeholder="Es: ho lasciato il gas aperto" />
        <div class="btn-row">
          <button class="btn-secondary" onclick="closeKwForm()">Annulla</button>
          <button class="btn-primary" onclick="saveKeyword()">Salva frase</button>
        </div>
      </div>
    </div>

    <div class="listening-bar" id="listeningBar">
      <div class="listening-dot"></div>
      <div class="listening-text">In ascolto… dì <span class="listening-kw" id="listeningKw">"…"</span></div>
    </div>

    <button class="test-btn" onclick="testVoice()">🧪 Testa il riconoscimento vocale</button>

    <div class="card" style="margin-top:14px;">
      <div class="card-title">🔒 Privacy & sicurezza</div>
      <div class="card-desc">Il riconoscimento vocale avviene <strong>direttamente sul tuo dispositivo</strong>. Nessun dato vocale viene inviato a server esterni. Disattiva quando non serve per risparmiare batteria.</div>
    </div>
  </div>

  <!-- CONTACTS -->
  <div class="screen" id="screen-contacts">
    <div class="section-lbl">I tuoi contatti di fiducia</div>
    <div id="contactsList"></div>
    <button class="add-contact-btn" onclick="openContactModal()">➕ Aggiungi contatto</button>
  </div>

  <!-- TIMER -->
  <div class="screen" id="screen-timer">
    <div class="timer-wrap">
      <div class="timer-circle">
        <svg class="timer-svg" viewBox="0 0 170 170">
          <circle class="timer-track" cx="85" cy="85" r="80"/>
          <circle class="timer-prog" id="timerProg" cx="85" cy="85" r="80"/>
        </svg>
        <div class="timer-num" id="timerNum">00:00</div>
        <div class="timer-lbl">rimasto</div>
      </div>

      <div class="timer-msg" id="timerMsg">Se non annulli prima della scadenza, i tuoi contatti riceveranno un allarme automatico.</div>

      <div class="section-lbl" style="align-self:flex-start;width:100%;">Durata</div>
      <div class="dur-grid">
        <button class="dur-btn sel" onclick="setDur(this,5)">5 minuti</button>
        <button class="dur-btn" onclick="setDur(this,15)">15 minuti</button>
        <button class="dur-btn" onclick="setDur(this,30)">30 minuti</button>
        <button class="dur-btn" onclick="setDur(this,60)">1 ora</button>
      </div>
      <button class="timer-main-btn" id="timerMainBtn" onclick="toggleTimer()">▶ Avvia timer</button>
    </div>
  </div>
</div>

<!-- FAKE CALL -->
<div class="fake-call-overlay" id="fakeCall">
  <div class="fake-call-sub">Chiamata in arrivo…</div>
  <div class="fake-call-avatar" id="fakeCallAvatar">MA</div>
  <div class="fake-call-name" id="fakeCallName">Mamma</div>
  <div class="fake-call-sub">SafeHer – chiamata simulata</div>
  <div class="call-btns">
    <button class="call-btn decline" onclick="endFakeCall()">📵</button>
    <button class="call-btn accept" onclick="endFakeCall()">📞</button>
  </div>
</div>

<!-- CONTACT MODAL -->
<div class="modal-overlay" id="contactModal">
  <div class="modal">
    <h3>➕ Nuovo contatto di fiducia</h3>
    <div class="modal-field">
      <label>Nome</label>
      <input class="input" type="text" id="cName" placeholder="Es: Mamma"/>
    </div>
    <div class="modal-field">
      <label>Relazione</label>
      <input class="input" type="text" id="cRel" placeholder="Es: Famiglia, Amica…"/>
    </div>
    <div class="modal-field">
      <label>Numero di telefono</label>
      <input class="input" type="tel" id="cPhone" placeholder="+39 333 1234567"/>
    </div>
    <div class="btn-row" style="margin-top:4px;">
      <button class="btn-secondary" onclick="closeContactModal()">Annulla</button>
      <button class="btn-primary" onclick="saveContact()">Salva</button>
    </div>
  </div>
</div>

<div class="toast" id="toast"></div>

<script>
// ── STATE ──
let contacts = JSON.parse(localStorage.getItem('sh_contacts') || 'null') || [
  {name:'Mamma', rel:'Famiglia', phone:'+39 333 0000000', initials:'MA'},
  {name:'Sara', rel:'Amica del cuore', phone:'+39 347 0000000', initials:'SA'}
];
let keyword = localStorage.getItem('sh_keyword') || '';
let voiceOn = false;
let recognition = null;
let sosTimer = null;
let sosProgressTimer = null;
let timerInterval = null;
let timerRunning = false;
let selMinutes = 5;
let timerTotal = 300;
let timerLeft = 300;
let recording = false;
let mediaRecorder = null;
let deferredPrompt = null;

// ── INSTALL ──
window.addEventListener('beforeinstallprompt', e => {
  e.preventDefault();
  deferredPrompt = e;
  document.getElementById('installBanner').classList.add('show');
});
window.addEventListener('appinstalled', () => {
  document.getElementById('installBanner').classList.remove('show');
  showToast('✅ SafeHer installata!');
});
function installApp() {
  if (deferredPrompt) {
    deferredPrompt.prompt();
    deferredPrompt.userChoice.then(() => { deferredPrompt = null; });
  } else {
    showToast('📱 Su iOS: usa "Condividi" → "Aggiungi a schermata Home"');
  }
}

// ── TABS ──
function showTab(name) {
  document.querySelectorAll('.screen').forEach(s => s.classList.remove('active'));
  document.querySelectorAll('.tab').forEach(t => t.classList.remove('active'));
  document.getElementById('screen-' + name).classList.add('active');
  document.getElementById('tab-' + name).classList.add('active');
}

// ── TOAST ──
function showToast(msg, dur = 3000) {
  const t = document.getElementById('toast');
  t.textContent = msg;
  t.classList.add('show');
  setTimeout(() => t.classList.remove('show'), dur);
}

// ── SOS ──
let sosProgress = 0;
function startSOS(e) {
  if (e) e.preventDefault();
  const btn = document.getElementById('sosBtn');
  const prog = document.getElementById('sosProgress');
  const wrap = document.getElementById('sosProgressWrap');
  btn.classList.add('pressing');
  wrap.classList.add('visible');
  sosProgress = 0;
  prog.style.width = '0%';
  sosProgressTimer = setInterval(() => {
    sosProgress += 100 / 30;
    prog.style.width = Math.min(sosProgress, 100) + '%';
  }, 100);
  sosTimer = setTimeout(triggerSOS, 3000);
  document.getElementById('sosHint').textContent = 'Tieni premuto…';
}
function cancelSOS() {
  clearTimeout(sosTimer);
  clearInterval(sosProgressTimer);
  const btn = document.getElementById('sosBtn');
  btn.classList.remove('pressing', 'fired');
  document.getElementById('sosProgressWrap').classList.remove('visible');
  document.getElementById('sosProgress').style.width = '0%';
  document.getElementById('sosHint').textContent = 'Tieni premuto 3 secondi per inviare l\'SOS';
}
function triggerSOS() {
  clearInterval(sosProgressTimer);
  const btn = document.getElementById('sosBtn');
  btn.classList.remove('pressing');
  btn.classList.add('fired');
  document.getElementById('sosProgress').style.width = '100%';
  document.getElementById('sosHint').textContent = '🚨 ALLARME INVIATO';
  document.getElementById('sosAlert').classList.add('show');

  if (navigator.geolocation) {
    navigator.geolocation.getCurrentPosition(pos => {
      const {latitude: lat, longitude: lng} = pos.coords;
      showToast(`📍 GPS: ${lat.toFixed(4)}, ${lng.toFixed(4)} — inviato!`, 4000);
    }, () => showToast('📍 Posizione inviata ai contatti!', 3000));
  }

  if ('Notification' in window && Notification.permission === 'granted') {
    new Notification('🚨 SafeHer – SOS attivato', {
      body: 'Il tuo allarme è stato inviato ai tuoi contatti di fiducia.',
      icon: 'icons/icon-192.png'
    });
  }

  setTimeout(() => {
    cancelSOS();
    document.getElementById('sosAlert').classList.remove('show');
  }, 6000);
}

// ── VOICE ──
function toggleVoice() {
  if (!keyword) { showToast('⚠️ Prima imposta una frase segreta!'); showTab('voice'); return; }
  voiceOn = !voiceOn;
  const tog = document.getElementById('voiceToggle');
  const lbl = document.getElementById('voiceToggleLabel');
  const dot = document.getElementById('voiceIndicator');
  const bar = document.getElementById('listeningBar');
  if (voiceOn) {
    tog.classList.add('on'); lbl.textContent = 'Attiva'; dot.classList.add('on');
    bar.classList.add('show');
    document.getElementById('listeningKw').textContent = '"' + keyword + '"';
    startRecognition();
    showToast('🎙️ Ascolto vocale attivato');
    requestNotificationPermission();
  } else {
    tog.classList.remove('on'); lbl.textContent = 'Non attiva'; dot.classList.remove('on');
    bar.classList.remove('show');
    stopRecognition();
    showToast('Ascolto vocale disattivato');
  }
}
function startRecognition() {
  const SR = window.SpeechRecognition || window.webkitSpeechRecognition;
  if (!SR) return;
  recognition = new SR();
  recognition.lang = 'it-IT';
  recognition.continuous = true;
  recognition.interimResults = true;
  recognition.onresult = e => {
    const t = Array.from(e.results).map(r => r[0].transcript).join(' ').toLowerCase();
    if (keyword && t.includes(keyword.toLowerCase())) {
      stopRecognition();
      voiceOn = false;
      document.getElementById('voiceToggle').classList.remove('on');
      document.getElementById('voiceToggleLabel').textContent = 'Non attiva';
      document.getElementById('voiceIndicator').classList.remove('on');
      document.getElementById('listeningBar').classList.remove('show');
      triggerSOS();
      showTab('sos');
    }
  };
  recognition.onend = () => { if (voiceOn) { try { recognition.start(); } catch(e){} } };
  recognition.onerror = () => { if (voiceOn) setTimeout(() => { try { recognition.start(); } catch(e){} }, 1000); };
  try { recognition.start(); } catch(e){}
}
function stopRecognition() {
  if (recognition) { try { recognition.stop(); } catch(e){} recognition = null; }
}
function openKwForm() { document.getElementById('kwForm').classList.add('open'); document.getElementById('kwInput').value = keyword; setTimeout(() => document.getElementById('kwInput').focus(), 100); }
function closeKwForm() { document.getElementById('kwForm').classList.remove('open'); }
function saveKeyword() {
  const v = document.getElementById('kwInput').value.trim();
  if (!v) { showToast('⚠️ Inserisci una frase!'); return; }
  keyword = v;
  localStorage.setItem('sh_keyword', keyword);
  document.getElementById('kwShow').textContent = '"' + keyword + '"';
  document.getElementById('kwShow').className = 'kw-value';
  document.getElementById('kwEditBtn').textContent = 'Modifica';
  document.getElementById('listeningKw').textContent = '"' + keyword + '"';
  closeKwForm();
  showToast('✅ Frase segreta salvata!');
}
function testVoice() {
  const SR = window.SpeechRecognition || window.webkitSpeechRecognition;
  if (!SR) { showToast('⚠️ Usa Chrome o Safari per il riconoscimento vocale'); return; }
  if (!keyword) { showToast('⚠️ Prima imposta una frase segreta!'); return; }
  const r = new SR();
  r.lang = 'it-IT'; r.continuous = false; r.interimResults = false;
  showToast('🎙️ Parla ora… dì la tua frase segreta', 4000);
  r.onresult = e => {
    const t = e.results[0][0].transcript.toLowerCase();
    if (t.includes(keyword.toLowerCase())) {
      showToast('✅ Riconosciuto! Il SOS si attiverebbe ora.', 4000);
    } else {
      showToast('❌ Sentito: "' + t + '" — riprova', 4000);
    }
  };
  r.onerror = () => showToast('⚠️ Errore microfono. Controlla i permessi.');
  r.start();
}

// ── CONTACTS ──
function saveContacts() { localStorage.setItem('sh_contacts', JSON.stringify(contacts)); }
function renderContacts() {
  document.getElementById('contactsList').innerHTML = contacts.map((c, i) => `
    <div class="contact-item">
      <div class="avatar">${c.initials || c.name.slice(0,2).toUpperCase()}</div>
      <div class="contact-info">
        <div class="contact-name">${c.name}</div>
        <div class="contact-rel">${c.rel}</div>
      </div>
      <div class="contact-actions">
        <div class="icon-btn" onclick="callContact(${i})" title="Chiama">📞</div>
        <div class="icon-btn" onclick="deleteContact(${i})" title="Elimina">🗑️</div>
      </div>
    </div>`).join('');
}
function callContact(i) {
  const c = contacts[i];
  if (c.phone) window.location.href = 'tel:' + c.phone.replace(/\s/g,'');
}
function deleteContact(i) {
  if (confirm('Eliminare ' + contacts[i].name + '?')) {
    contacts.splice(i, 1); saveContacts(); renderContacts();
    showToast('Contatto eliminato');
  }
}
function openContactModal() { document.getElementById('contactModal').classList.add('open'); }
function closeContactModal() {
  document.getElementById('contactModal').classList.remove('open');
  ['cName','cRel','cPhone'].forEach(id => document.getElementById(id).value = '');
}
function saveContact() {
  const name = document.getElementById('cName').value.trim();
  if (!name) { showToast('⚠️ Inserisci un nome!'); return; }
  contacts.push({
    name, rel: document.getElementById('cRel').value || 'Contatto',
    phone: document.getElementById('cPhone').value,
    initials: name.slice(0,2).toUpperCase()
  });
  saveContacts(); renderContacts(); closeContactModal();
  showToast('✅ Contatto aggiunto!');
}

// ── TIMER ──
function pad(n) { return n.toString().padStart(2,'0'); }
function updateTimerDisplay(s) {
  document.getElementById('timerNum').textContent = pad(Math.floor(s/60)) + ':' + pad(s%60);
  const pct = timerRunning ? (timerLeft / timerTotal) : 1;
  const circ = 2 * Math.PI * 80;
  document.getElementById('timerProg').style.strokeDashoffset = circ * (1 - pct);
}
function setDur(btn, mins) {
  if (timerRunning) return;
  document.querySelectorAll('.dur-btn').forEach(b => b.classList.remove('sel'));
  btn.classList.add('sel');
  selMinutes = mins; timerTotal = mins * 60; timerLeft = timerTotal;
  updateTimerDisplay(timerLeft);
}
function toggleTimer() {
  if (!timerRunning) {
    timerRunning = true; timerLeft = selMinutes * 60; timerTotal = timerLeft;
    document.getElementById('timerMainBtn').textContent = '⏹ Annulla timer';
    document.getElementById('timerMainBtn').classList.add('stop');
    document.getElementById('timerMsg').textContent = 'Timer attivo! Annullalo prima che scada.';
    timerInterval = setInterval(() => {
      timerLeft--;
      updateTimerDisplay(timerLeft);
      if (timerLeft <= 120 && timerLeft > 0) showToast('⚠️ ' + timerLeft + 's al scadenza!');
      if (timerLeft <= 0) {
        clearInterval(timerInterval); timerRunning = false;
        document.getElementById('timerMainBtn').textContent = '▶ Avvia timer';
        document.getElementById('timerMainBtn').classList.remove('stop');
        document.getElementById('timerMsg').textContent = '⏰ Tempo scaduto! Allarme inviato ai tuoi contatti.';
        triggerSOS(); showTab('sos');
      }
    }, 1000);
  } else {
    clearInterval(timerInterval); timerRunning = false;
    timerLeft = selMinutes * 60; updateTimerDisplay(timerLeft);
    document.getElementById('timerMainBtn').textContent = '▶ Avvia timer';
    document.getElementById('timerMainBtn').classList.remove('stop');
    document.getElementById('timerMsg').textContent = 'Timer annullato. Sei al sicuro! ✅';
  }
}

// ── QUICK ACTIONS ──
function startFakeCall() {
  const c = contacts[0] || {name:'Amica', initials:'AM'};
  document.getElementById('fakeCallName').textContent = c.name;
  document.getElementById('fakeCallAvatar').textContent = c.initials || c.name.slice(0,2).toUpperCase();
  document.getElementById('fakeCall').classList.add('show');
}
function endFakeCall() { document.getElementById('fakeCall').classList.remove('show'); }
function sendLocation() {
  if (navigator.geolocation) {
    navigator.geolocation.getCurrentPosition(pos => {
      const {latitude: lat, longitude: lng} = pos.coords;
      const url = `https://maps.google.com/?q=${lat},${lng}`;
      if (navigator.share) {
        navigator.share({ title: '📍 La mia posizione – SafeHer', url });
      } else {
        window.open(url, '_blank');
      }
    }, () => showToast('⚠️ Abilita il GPS per inviare la posizione'));
  } else { showToast('⚠️ GPS non disponibile'); }
}
function call112() { window.location.href = 'tel:112'; }
async function startRecording() {
  if (recording) {
    if (mediaRecorder) mediaRecorder.stop();
    recording = false;
    document.getElementById('recIcon').textContent = '🎙️';
    document.getElementById('recLabel').textContent = 'Registra audio';
    showToast('⏹ Registrazione salvata');
    return;
  }
  try {
    const stream = await navigator.mediaDevices.getUserMedia({audio: true});
    mediaRecorder = new MediaRecorder(stream);
    const chunks = [];
    mediaRecorder.ondataavailable = e => chunks.push(e.data);
    mediaRecorder.onstop = () => {
      const blob = new Blob(chunks, {type:'audio/webm'});
      const url = URL.createObjectURL(blob);
      const a = document.createElement('a');
      a.href = url; a.download = 'safeher-audio-' + Date.now() + '.webm'; a.click();
      stream.getTracks().forEach(t => t.stop());
    };
    mediaRecorder.start();
    recording = true;
    document.getElementById('recIcon').textContent = '⏹';
    document.getElementById('recLabel').textContent = 'Stop registrazione';
    showToast('🔴 Registrazione avviata…');
  } catch(e) { showToast('⚠️ Permesso microfono negato'); }
}

// ── NOTIFICATIONS ──
function requestNotificationPermission() {
  if ('Notification' in window && Notification.permission === 'default') {
    Notification.requestPermission();
  }
}

// ── INIT ──
if ('serviceWorker' in navigator) {
  navigator.serviceWorker.register('sw.js').catch(() => {});
}
if (keyword) {
  document.getElementById('kwShow').textContent = '"' + keyword + '"';
  document.getElementById('kwShow').className = 'kw-value';
  document.getElementById('kwEditBtn').textContent = 'Modifica';
}
renderContacts();
updateTimerDisplay(timerLeft);
// Close modals on backdrop click
document.getElementById('contactModal').addEventListener('click', function(e) {
  if (e.target === this) closeContactModal();
});
</script>
</body>
</html>
